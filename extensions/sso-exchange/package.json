{
  "name": "sso-exchange",
  "version": "1.0.0",
  "description": "Validates native Apple/Google identity tokens and returns Directus access tokens",
  "type": "module",
  "directus:extension": {
    "type": "endpoint",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "^11.0.0"
  },
  "scripts": {
    "build": "npx @directus/extensions-sdk build",
    "dev": "npx @directus/extensions-sdk build -w"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^13.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "argon2": "^0.31.2",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "nanoid": "^3.3.11"
  },
  "license": "MIT"
}
